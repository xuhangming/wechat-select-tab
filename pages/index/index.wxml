<!--pages/index/index.wxml-->
<view class="container">
  <!-- 未登录状态 - 显示登录引导 -->
  <view class="login-guide" wx:if="{{!hasUserInfo}}">
    <view class="login-content">
      <view class="login-icon">🎲</view>
      <text class="login-title">欢迎使用抽签助手</text>
      <text class="login-desc">请选择头像和输入昵称</text>
      
      <!-- 头像选择 -->
      <view class="avatar-section">
        <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="avatar-preview" src="{{avatarUrl}}" mode="aspectFill" wx:if="{{avatarUrl}}"></image>
          <view class="avatar-placeholder" wx:else>
            <text class="avatar-placeholder-icon">📷</text>
            <text class="avatar-placeholder-text">选择头像</text>
          </view>
        </button>
      </view>
      
      <!-- 昵称输入 -->
      <view class="nickname-section">
        <input 
          class="nickname-input" 
          type="nickname" 
          placeholder="请输入昵称" 
          value="{{nickName}}"
          bindinput="onNicknameInput"
          maxlength="20"
        />
      </view>
      
      <!-- 完成按钮 -->
      <button class="login-button" bindtap="completeLogin">
        完成登录
      </button>
      
      <text class="login-hint">选择头像和输入昵称后即可使用</text>
    </view>
  </view>

  <!-- 已登录状态 - 显示完整功能 -->
  <view class="main-content" wx:else>
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <text class="user-name">{{userInfo.nickName}}</text>
      <button class="logout-btn" bindtap="logout">退出登录</button>
    </view>

    <!-- 快捷导航卡片 -->
    <view class="nav-cards">
      <view class="nav-card" bindtap="navigateToParticipated">
        <view class="nav-icon-wrapper">
          <view class="nav-icon">👥</view>
        </view>
        <text class="nav-title">我参与的抽签</text>
        <view class="nav-arrow">›</view>
      </view>
      <view class="nav-card" bindtap="navigateToCreated">
        <view class="nav-icon-wrapper">
          <view class="nav-icon">📝</view>
        </view>
        <text class="nav-title">我创建的抽签</text>
        <view class="nav-arrow">›</view>
      </view>
    </view>

    <!-- 常用功能 -->
    <view class="function-section">
      <view class="section-header">
        <text class="section-title">常用功能</text>
      </view>
      <view class="function-grid">
        <view class="function-item" bindtap="navigateToCreate">
          <view class="function-icon create-icon">
            <text class="icon-text">+</text>
          </view>
          <text class="function-name">创建抽签</text>
        </view>
        <view class="function-item" bindtap="navigateToHistory">
          <view class="function-icon history-icon">
            <text class="icon-text">📋</text>
          </view>
          <text class="function-name">历史记录</text>
        </view>
      </view>
    </view>
  </view>
</view>
