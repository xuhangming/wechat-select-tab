/* pages/history/history.wxss */

/* 页面容器 */
.page {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  gap: 24rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 8rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #1f2937;
  font-weight: 500;
}

.empty-hint {
  font-size: 26rpx;
  color: #9ca3af;
  margin-bottom: 24rpx;
}

.create-button {
  width: 320rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #a855f7 0%, #ec4899 100%);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(168, 85, 247, 0.35);
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.create-button::after {
  border: none;
}

/* 列表容器 */
.list-container {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 抽签卡片 - 参考详情页活动信息样式 */
.lottery-card {
  background: linear-gradient(135deg, #a855f7 0%, #ec4899 100%);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(168, 85, 247, 0.25);
}

.lottery-card:active {
  opacity: 0.9;
  transform: scale(0.98);
  transition: all 0.2s ease;
}

.card-content {
  position: relative;
  padding-right: 60rpx;
}

.title-row {
  margin-bottom: 20rpx;
  padding-right: 100rpx;
}

.card-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1.4;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.status-badge {
  position: absolute;
  top: 0;
  right: 60rpx;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
}

.status-badge.not_started {
  background: rgba(255, 255, 255, 0.25);
}

.status-badge.ongoing {
  background: rgba(255, 255, 255, 0.25);
}

.status-badge.ended {
  background: rgba(0, 0, 0, 0.15);
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #ffffff;
}

.stats-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.stats-icon {
  font-size: 28rpx;
  line-height: 1;
}

.stats-text {
  font-size: 28rpx;
  color: #ffffff;
  opacity: 0.95;
  font-weight: 500;
}

.time-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.time-icon {
  font-size: 28rpx;
  line-height: 1;
}

.time-text {
  font-size: 26rpx;
  color: #ffffff;
  opacity: 0.95;
  line-height: 1.4;
}

.arrow-icon {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 56rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 300;
  line-height: 1;
}
